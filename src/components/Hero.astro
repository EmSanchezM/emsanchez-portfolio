---
---

<section class="hero" id="hero">
  <div class="container">
    <div class="hero__wrapper">
      <div class="hero__content">
        <p class="hero__subtitle">Software Engineer & Architect</p>
        <h1 class="hero__title">
          Hi, I'm Elvin, <span class="hero__accent">Software engineer.</span>
        </h1>
        <p class="hero__description">
          Senior Developer with 5+ years building production systems that handle real money, real users, and real complexity. From fintech payment engines to enterprise e-commerce platforms across Latin America, the U.S., and Europe, I work across the entire stack — Java, Spring Boot, Node.js, React — delivering solutions that companies depend on to operate and grow. Open to freelance projects and new challenges.
        </p>
        <div class="hero__scroll">
          <a href="#about" class="hero__scroll-btn" aria-label="Scroll to explore">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
          </a>
          <span class="hero__scroll-label">Explore Portfolio</span>
        </div>
      </div>
      <div class="hero__image-wrapper">
        <div class="hero__glow"></div>
        <div class="hero__image-container">
          <img
            src="/images/em-sanchez.webp"
            srcset="/images/em-sanchez-250.webp 250w, /images/em-sanchez-475.webp 475w"
            sizes="(max-width: 968px) 250px, 475px"
            alt="Fotografía de Elvin Sánchez"
            class="hero__img"
            fetchpriority="high"
            decoding="sync"
            width="475"
            height="475"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 12rem;
    padding-bottom: 6rem;
  }

  .hero__wrapper {
    display: grid;
    gap: 4rem;
    align-items: center;
  }

  .hero__subtitle {
    font-family: var(--ff-body);
    color: var(--secondary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: var(--fs-label-sm);
    margin-bottom: 1.6rem;
  }

  .hero__title {
    font-size: var(--fs-display);
    font-weight: var(--fw-bold);
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin-bottom: 3.2rem;
  }

  .hero__accent {
    color: var(--primary);
  }

  .hero__description {
    font-size: var(--fs-body-lg);
    color: var(--on-surface-variant);
    max-width: 50rem;
    line-height: 1.6;
  }

  .hero__scroll {
    margin-top: 5rem;
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }

  .hero__scroll-btn {
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 50%;
    border: 1px solid rgba(68, 70, 84, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    transition: var(--transition);
  }

  .hero__scroll-btn:hover {
    border-color: var(--primary);
  }

  .hero__scroll-label {
    font-family: var(--ff-body);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--on-surface-variant);
  }

  .hero__image-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero__glow {
    position: absolute;
    top: -4rem;
    right: -4rem;
    width: 25rem;
    height: 25rem;
    background: rgba(33, 70, 199, 0.2);
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .hero__image-container {
    position: relative;
    z-index: 1;
    width: 26rem;
    height: 34rem;
    border-radius: 1.2rem;
    overflow: hidden;
    background: var(--surface-container-high);
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero__img:hover {
    filter: grayscale(0);
  }

  @media screen and (max-width: 968px) {
    .hero {
      padding-top: 10rem;
      padding-bottom: 4rem;
    }

    .hero__wrapper {
      text-align: center;
    }

    .hero__image-wrapper {
      order: -1;
    }

    .hero__image-container {
      width: 20rem;
      height: 26rem;
    }

    .hero__description {
      margin: 0 auto;
    }

    .hero__scroll {
      justify-content: center;
    }

    .hero__glow {
      width: 16rem;
      height: 16rem;
      top: -2rem;
      right: auto;
    }
  }

  @media screen and (min-width: 969px) {
    .hero__wrapper {
      grid-template-columns: 1fr auto;
    }

    .hero__image-container {
      width: 32rem;
      height: 42rem;
    }
  }
</style>
