---
---

<nav class="dock" id="header" aria-label="Primary">
  <a href="/" class="dock__logo" aria-label="EMSANCHEZ — Home">EMSANCHEZ</a>
  <div class="dock__menu" id="nav__menu">
    <ul class="dock__list">
      <li class="dock__item">
        <a href="/#work" class="dock__link">Work</a>
      </li>
      <li class="dock__item">
        <a href="/#about" class="dock__link">About</a>
      </li>
      <li class="dock__item">
        <a href="/#contact" class="dock__link">Contact</a>
      </li>
    </ul>
    <a href="/resume" class="dock__menu-cta">Resume</a>
  </div>
  <div class="dock__actions">
    <a href="/resume" class="dock__cta">Resume</a>
    <button
      class="dock__toggle"
      id="nav__toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="nav__menu"
      type="button"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</nav>

<style>
  .dock {
    position: fixed;
    top: 1.5rem;
    left: 0;
    right: 0;
    margin-inline: auto;
    width: 90%;
    max-width: 72rem;
    border-radius: 9999px;
    background: rgba(19, 19, 19, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 1.2rem 2.4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: var(--zindex-fixed);
    box-shadow: 0 8px 32px rgba(0, 0, 100, 0.1);
  }

  .dock__logo {
    font-family: var(--ff-headline);
    font-size: 1.8rem;
    font-weight: var(--fw-bold);
    letter-spacing: -0.04em;
    color: var(--on-surface);
  }

  .dock__list {
    display: flex;
    gap: 3.2rem;
    align-items: center;
  }

  .dock__link {
    font-family: var(--ff-headline);
    font-weight: var(--fw-medium);
    font-size: var(--fs-label-md);
    letter-spacing: -0.02em;
    color: var(--on-surface-variant);
    transition: var(--transition);
  }

  .dock__link:hover,
  .dock__link:focus-visible,
  .dock__link--active {
    color: var(--primary);
  }

  .dock__logo:focus-visible,
  .dock__link:focus-visible,
  .dock__cta:focus-visible,
  .dock__menu-cta:focus-visible,
  .dock__toggle:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .dock__actions {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .dock__cta {
    background: var(--primary-container);
    color: var(--on-primary-container);
    padding: 0.8rem 2rem;
    border-radius: 9999px;
    font-family: var(--ff-headline);
    font-weight: var(--fw-medium);
    font-size: var(--fs-label-sm);
    transition: var(--transition);
  }

  .dock__cta:hover {
    transform: scale(0.95);
  }

  .dock__menu-cta {
    display: none;
  }

  .dock__toggle {
    display: none;
    background: none;
    border: none;
    color: var(--primary);
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 9999px;
    transition: var(--transition);
  }

  .dock__toggle:hover,
  .dock__toggle:focus-visible {
    background: rgba(184, 195, 255, 0.12);
  }

  @media screen and (max-width: 968px) {
    .dock {
      border-radius: 1.2rem;
      top: 1rem;
      padding: 1rem 1.6rem;
      background: rgba(19, 19, 19, 0.9);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }

    .dock__menu {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(19, 19, 19, 0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 3rem;
      z-index: var(--zindex-menu);
    }

    .dock__menu--open {
      display: flex;
    }

    .dock__list {
      flex-direction: column;
      gap: 4rem;
    }

    .dock__menu-cta {
      display: inline-block;
      background: var(--primary-container);
      color: var(--on-primary-container);
      padding: 1.2rem 3.2rem;
      border-radius: 9999px;
      font-family: var(--ff-headline);
      font-weight: var(--fw-medium);
      font-size: var(--fs-label-md);
      transition: var(--transition);
    }

    .dock__menu-cta:hover,
    .dock__menu-cta:active {
      transform: scale(0.95);
    }

    .dock__link {
      font-size: var(--fs-headline-md);
    }

    .dock__toggle {
      display: block;
    }

    .dock__logo,
    .dock__actions {
      z-index: var(--zindex-fixed);
    }

    .dock__cta {
      display: none;
    }
  }
</style>

<script>
  const navMenu = document.getElementById('nav__menu');
  const navToggle = document.getElementById('nav__toggle');
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    navMenu!.classList.toggle('dock__menu--open', isMenuOpen);
    navToggle!.setAttribute('aria-expanded', isMenuOpen.toString());
    document.body.style.overflow = isMenuOpen ? 'hidden' : '';
  }

  navToggle!.addEventListener('click', toggleMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isMenuOpen) toggleMenu();
  });

  document.querySelectorAll('#nav__menu a').forEach(link => {
    link.addEventListener('click', () => {
      if (isMenuOpen) {
        toggleMenu();
      }
    });
  });
</script>
