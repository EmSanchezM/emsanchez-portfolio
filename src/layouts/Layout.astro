---
interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import "@fontsource-variable/inter";
import "@fontsource-variable/space-grotesk";

const {
  title,
  description = "Elvin Sanchez — Senior Software Engineer. 5+ years building production systems: fintech payment engines, e-commerce platforms. Java, Spring Boot, Node.js, React.",
  image = "/images/em-sanchez-475.webp",
  noindex = false,
} = Astro.props;

const siteURL = Astro.site ?? new URL("https://emsanchez.com");
const canonicalURL = new URL(Astro.url.pathname, siteURL).href;
const socialImage = new URL(image, siteURL).href;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Elvin Sanchez",
  url: siteURL.href,
  image: socialImage,
  jobTitle: "Software Engineer",
  description,
  sameAs: [
    "https://github.com/EmSanchezM",
    "https://www.linkedin.com/in/elvin-sanchez-m/",
  ],
  knowsAbout: [
    "Java",
    "Spring Boot",
    "Node.js",
    "React",
    "TypeScript",
    "Software Architecture",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#131313" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Elvin Sanchez" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Elvin Sanchez — Software Engineer" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- LCP hero image preload -->
    <link
      rel="preload"
      as="image"
      href="/images/em-sanchez-250.webp"
      media="(max-width: 968px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/images/em-sanchez-475.webp"
      media="(min-width: 969px)"
      fetchpriority="high"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
<style is:global>
  :root {
    /* Surface hierarchy */
    --background: #131313;
    --surface-container-lowest: #0E0E0E;
    --surface-container-low: #1C1B1B;
    --surface-container: #20201F;
    --surface-container-high: #2A2A2A;
    --surface-container-highest: #353535;

    /* Primary */
    --primary: #B8C3FF;
    --primary-container: #2146C7;
    --on-primary: #002487;
    --on-primary-container: #BBC6FF;

    /* Secondary */
    --secondary: #89D0ED;
    --secondary-container: #00627B;

    /* Neutral / text */
    --on-surface: #E5E2E1;
    --on-surface-variant: #C4C5D6;
    --outline: #8E90A0;
    --outline-variant: #444654;

    /* Typography */
    --ff-headline: 'Space Grotesk Variable', 'Space Grotesk', system-ui, sans-serif;
    --ff-body: 'Inter Variable', 'Inter', system-ui, sans-serif;

    --fs-display: clamp(3.5rem, 8vw, 8rem);
    --fs-headline-lg: 3rem;
    --fs-headline-md: 2.25rem;
    --fs-title-lg: 1.75rem;
    --fs-body-lg: 1.8rem;
    --fs-body-md: 1.6rem;
    --fs-label-md: 1.4rem;
    --fs-label-sm: 1.2rem;

    --fw-regular: 400;
    --fw-medium: 500;
    --fw-semibold: 600;
    --fw-bold: 700;

    /* Spacing */
    --spacing-4: 1rem;
    --spacing-6: 1.5rem;
    --spacing-8: 2.75rem;
    --spacing-12: 4rem;
    --spacing-16: 5.5rem;
    --spacing-24: 8.5rem;

    /* Z-index */
    --zindex-menu: 1000;
    --zindex-fixed: 1010;

    /* Layout */
    --width-container: 98rem;

    /* Transitions */
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

    /* Shadows */
    --shadow-ambient: 0 8px 32px rgba(184, 195, 255, 0.06);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    color: var(--on-surface);
    font-family: var(--ff-headline);
    font-weight: var(--fw-bold);
  }

  html {
    font-size: 62.5%;
    scroll-behavior: smooth;
  }

  body,
  h1,
  h2,
  h3,
  h4,
  ul,
  p {
    margin: 0;
    padding: 0;
  }

  ul {
    list-style-type: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    text-decoration: none;
    color: var(--on-surface-variant);
  }

  :focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .skip-link {
    position: absolute;
    top: -100px;
    left: 1rem;
    z-index: 9999;
    padding: 0.8rem 1.6rem;
    background: var(--primary);
    color: var(--on-primary);
    font-family: var(--ff-headline);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-label-md);
    border-radius: 0.8rem;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 1rem;
  }

  main {
    overflow: hidden;
  }

  body {
    background-color: var(--background);
    font-family: var(--ff-body);
    font-size: var(--fs-body-md);
    color: var(--on-surface-variant);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  ::selection {
    background-color: rgba(184, 195, 255, 0.3);
  }

  .container {
    width: 90%;
    max-width: var(--width-container);
    margin: auto;
  }

  .grid {
    display: grid;
    gap: 3rem;
  }

  .section {
    padding: 5rem 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    padding: 1.5rem 4rem;
    font-family: var(--ff-headline);
    font-weight: var(--fw-bold);
    font-size: var(--fs-label-md);
    border: none;
    cursor: pointer;
    transition: var(--transition);
  }

  .btn--primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-container));
    color: var(--on-primary);
    border-radius: 9999px;
  }

  .btn--primary:hover {
    transform: scale(0.97);
  }

  .btn--ghost {
    background: transparent;
    color: var(--primary);
    border-radius: 9999px;
  }

  .btn--ghost:hover {
    background-color: rgba(184, 195, 255, 0.1);
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
    html {
      scroll-behavior: auto;
    }
  }
</style>
