---
interface Props {
  title: string;
}
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Elvin Sanchez — Software Engineer. Crafting digital experiences through precise engineering and intentional design." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="preload"
      as="image"
      href="/images/em-sanchez-250.webp"
      media="(max-width: 968px)"
      fetchpriority="high"
      imagesizes="250px"
      imagesrcset="/images/em-sanchez-250.webp 250w"
    />
    <link
      rel="preload"
      as="image"
      href="/images/em-sanchez-475.webp"
      media="(min-width: 969px)"
      fetchpriority="high"
      imagesizes="475px"
      imagesrcset="/images/em-sanchez-475.webp 475w"
    />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
<style is:global>
  :root {
    /* Surface hierarchy */
    --background: #131313;
    --surface-container-lowest: #0E0E0E;
    --surface-container-low: #1C1B1B;
    --surface-container: #20201F;
    --surface-container-high: #2A2A2A;
    --surface-container-highest: #353535;

    /* Primary */
    --primary: #B8C3FF;
    --primary-container: #2146C7;
    --on-primary: #002487;
    --on-primary-container: #BBC6FF;

    /* Secondary */
    --secondary: #89D0ED;
    --secondary-container: #00627B;

    /* Neutral / text */
    --on-surface: #E5E2E1;
    --on-surface-variant: #C4C5D6;
    --outline: #8E90A0;
    --outline-variant: #444654;

    /* Typography */
    --ff-headline: 'Space Grotesk', sans-serif;
    --ff-body: 'Inter', sans-serif;

    --fs-display: clamp(3.5rem, 8vw, 8rem);
    --fs-headline-lg: 3rem;
    --fs-headline-md: 2.25rem;
    --fs-title-lg: 1.75rem;
    --fs-body-lg: 1.8rem;
    --fs-body-md: 1.6rem;
    --fs-label-md: 1.4rem;
    --fs-label-sm: 1.2rem;

    --fw-regular: 400;
    --fw-medium: 500;
    --fw-semibold: 600;
    --fw-bold: 700;

    /* Spacing */
    --spacing-4: 1rem;
    --spacing-6: 1.5rem;
    --spacing-8: 2.75rem;
    --spacing-12: 4rem;
    --spacing-16: 5.5rem;
    --spacing-24: 8.5rem;

    /* Z-index */
    --zindex-menu: 1000;
    --zindex-fixed: 1010;

    /* Layout */
    --width-container: 98rem;

    /* Transitions */
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

    /* Shadows */
    --shadow-ambient: 0 8px 32px rgba(184, 195, 255, 0.06);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    color: var(--on-surface);
    font-family: var(--ff-headline);
    font-weight: var(--fw-bold);
  }

  html {
    font-size: 62.5%;
    scroll-behavior: smooth;
  }

  body,
  h1,
  h2,
  h3,
  h4,
  ul,
  p {
    margin: 0;
    padding: 0;
  }

  ul {
    list-style-type: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    text-decoration: none;
    color: var(--on-surface-variant);
  }

  main {
    overflow: hidden;
  }

  body {
    background-color: var(--background);
    font-family: var(--ff-body);
    font-size: var(--fs-body-md);
    color: var(--on-surface-variant);
    line-height: 1.5;
  }

  ::selection {
    background-color: rgba(184, 195, 255, 0.3);
  }

  .container {
    width: 90%;
    max-width: var(--width-container);
    margin: auto;
  }

  .grid {
    display: grid;
    gap: 3rem;
  }

  .section {
    padding: 5rem 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    padding: 1.5rem 4rem;
    font-family: var(--ff-headline);
    font-weight: var(--fw-bold);
    font-size: var(--fs-label-md);
    border: none;
    cursor: pointer;
    transition: var(--transition);
  }

  .btn--primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-container));
    color: var(--on-primary);
    border-radius: 9999px;
  }

  .btn--primary:hover {
    transform: scale(0.97);
  }

  .btn--ghost {
    background: transparent;
    color: var(--primary);
    border-radius: 9999px;
  }

  .btn--ghost:hover {
    background-color: rgba(184, 195, 255, 0.1);
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
    html {
      scroll-behavior: auto;
    }
  }
</style>
