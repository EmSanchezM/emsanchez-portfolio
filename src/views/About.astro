---
---

<section class="about section" id="about">
  <div class="container">
    <div class="about__grid">
      <div class="about__text">
        <h2 class="about__title">About me</h2>
        <p class="about__description">
          With over 4 years of experience in full-stack development, I focus on building scalable architectures that don't compromise on user experience. I believe code is a craft that requires both technical rigor and creative intuition.
        </p>
        <p class="about__description">
          Currently focused on Java ecosystems, React, Distributed Systems, and refining modern web interfaces with a strong emphasis on performance and clean architecture.
        </p>
      </div>
      <div class="about__tech">
        <h3 class="about__tech-label">Core Technologies</h3>
        <div class="about__chips">
          <span class="about__chip">Java</span>
          <span class="about__chip">TypeScript</span>
          <span class="about__chip">React</span>
          <span class="about__chip">Next.js</span>
          <span class="about__chip">Node.js</span>
          <span class="about__chip">Spring Boot</span>
          <span class="about__chip">PostgreSQL</span>
          <span class="about__chip">Docker</span>
          <span class="about__chip">GraphQL</span>
          <span class="about__chip">AWS</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    margin-bottom: var(--spacing-24);
  }

  .about__grid {
    display: grid;
    gap: 4rem;
  }

  .about__title {
    font-family: var(--ff-headline);
    font-size: var(--fs-headline-lg);
    font-weight: var(--fw-bold);
    margin-bottom: 3.2rem;
  }

  .about__description {
    color: var(--on-surface-variant);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 50rem;
  }

  .about__tech {
    background-color: var(--surface-container-low);
    border-radius: 1.2rem;
    padding: 3.2rem 4rem;
  }

  .about__tech-label {
    font-family: var(--ff-body);
    font-size: var(--fs-label-sm);
    color: var(--secondary);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: var(--fw-bold);
    margin-bottom: 2.4rem;
  }

  .about__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
  }

  .about__chip {
    padding: 0.8rem 1.6rem;
    background-color: var(--surface-container-high);
    color: var(--on-surface-variant);
    font-size: var(--fs-label-sm);
    border-radius: 0.25rem;
    transition: var(--transition);
  }

  .about__chip:hover {
    color: var(--primary);
  }

  @media screen and (min-width: 769px) {
    .about__grid {
      grid-template-columns: 5fr 6fr;
      gap: 6rem;
    }
  }
</style>
