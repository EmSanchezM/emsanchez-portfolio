  <div class="container">
    <div class="resume-intro__content">
      <p class="resume-intro__label">Resume</p>
      <h1 class="resume-intro__title">Elvin Sanchez</h1>
      <p class="resume-intro__subtitle">Software Engineer & Architect</p>
      <p class="resume-intro__description">
        Software engineer with +4 years of experience in full-stack development.
        Proficient in Java, JavaScript, TypeScript and frameworks like React, Next.js,
        Spring Boot. Experienced in database design, API integration, scalable
        architectures, and working with cross-functional teams.
      </p>
      <div class="resume-intro__contact">
        <a href="mailto:emsanchez891@gmail.com" class="resume-intro__link">emsanchez891@gmail.com</a>
        <span class="resume-intro__separator">·</span>
        <a href="https://github.com/EmSanchezM" target="_blank" class="resume-intro__link">GitHub</a>
        <span class="resume-intro__separator">·</span>
