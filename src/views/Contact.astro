---
import { Github, Linkedin, Mail } from "@/components/icons";
---

<section id="contact" class="contact section">
  <div class="container">
    <div class="contact__card">
      <h2 class="contact__title">
        Let's build something<br />extraordinary.
      </h2>
      <div class="contact__links">
        <a href="mailto:emsanchez891@gmail.com" class="contact__link-item">
          <div class="contact__icon-circle">
            <Mail />
          </div>
          <span class="contact__label">Email</span>
        </a>
        <a
          href="https://www.linkedin.com/in/elvin-sanchez-medina"
          target="_blank"
          class="contact__link-item"
        >
          <div class="contact__icon-circle">
            <Linkedin />
          </div>
          <span class="contact__label">LinkedIn</span>
        </a>
        <a
          href="https://github.com/EmSanchezM"
          target="_blank"
          class="contact__link-item"
        >
          <div class="contact__icon-circle">
            <Github />
          </div>
          <span class="contact__label">GitHub</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    margin-bottom: var(--spacing-24);
  }

  .contact__card {
    background-color: var(--surface-container-low);
    border-radius: 2.4rem;
    padding: 8rem 4rem;
    text-align: center;
  }

  .contact__title {
    font-family: var(--ff-headline);
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: var(--fw-bold);
    letter-spacing: -0.04em;
    margin-bottom: 5rem;
  }

  .contact__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4rem;
  }

  .contact__link-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;
  }

  .contact__icon-circle {
    width: 6.4rem;
    height: 6.4rem;
    border-radius: 50%;
    background-color: var(--surface-container-high);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    transition: var(--transition);
  }

  .contact__link-item:hover .contact__icon-circle {
    background-color: var(--primary);
    color: var(--on-primary);
  }

  .contact__label {
    font-family: var(--ff-body);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--on-surface-variant);
  }

  @media screen and (max-width: 560px) {
    .contact__card {
      padding: 5rem 2rem;
      border-radius: 1.6rem;
    }

    .contact__links {
      gap: 3rem;
    }
  }
</style>
